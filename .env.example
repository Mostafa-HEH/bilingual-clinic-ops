# App
NODE_ENV=development
PORT=3000

# Postgres container (consumed by docker-compose.yml)
POSTGRES_USER=clinic_user
POSTGRES_PASSWORD=clinic_password
POSTGRES_DB=clinic_ops
POSTGRES_PORT=5432

# API -> Postgres connection (must match the values above)
DATABASE_URL=postgresql://clinic_user:clinic_password@localhost:5432/clinic_ops
